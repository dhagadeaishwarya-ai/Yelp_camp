<% layout('layouts/boilerplate') %>

<div class="container mt-5">
  <div class="row justify-content-center">
    
    <div class="col-md-6 col-lg-5">

      <h1 class="mb-4 text-center">Create New Campground</h1>

      <form action="/campgrounds" method="POST">

        <!-- Title -->
        <div class="mb-3">
          <label for="title" class="form-label">Campground Title</label>
          <input type="text" id="title" name="campground[title]" 
                 class="form-control" placeholder="Enter campground name" required>
        </div>

        <!-- Location -->
        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input type="text" id="location" name="campground[location]" 
                 class="form-control" placeholder="Enter location" required>
        </div>

        <!-- Image -->
        <div class="mb-3">
          <label for="image" class="form-label">Image URL</label>
          <input type="text" id="image" name="campground[image]" 
                 class="form-control" placeholder="Paste image URL">
        </div>

        <!-- Price -->
        <div class="mb-3">
          <label for="price" class="form-label">Price (per night)</label>
          <input type="number" id="price" name="campground[price]" 
                 class="form-control" placeholder="0.00" min="0" step="0.01" required>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="campground[description]" 
                    class="form-control" rows="4"></textarea>
        </div>

        <!-- Buttons -->
        <div class="d-grid mb-3">
          <button type="submit" class="btn btn-success">
            Create Campground
          </button>
        </div>

      </form>

      <!-- Back Link -->
      <div class="text-center">
        <a href="/campgrounds" class="btn btn-outline-secondary">
          ← Back to All Campgrounds
        </a>
      </div>

    </div>

  </div>
</div>