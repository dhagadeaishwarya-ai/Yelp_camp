<% layout('layouts/boilerplate') %>
   

    <div class="container mt-5">
  <div class="row justify-content-center">
    
    <div class="col-md-6 col-lg-5">

      <h1 class="mb-4 text-center">Edit Campground</h1>

    <form action="/campgrounds/show/<%= campground._id %>?_method=PUT" method="POST" novalidate class="needs-validation" >

        <!-- Title -->
        <div class="mb-3">
          <label for="title" class="form-label">Campground Title</label>
          <input type="text" id="title" name="campground[title]" 
                 class="form-control" value="<%= campground.title %>" required>
        <div class="invalid-feedback">
  Please fill this field
</div></div>

        <!-- Location -->
        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input type="text" id="location" name="campground[location]" 
                 class="form-control" value="<%= campground.location %>" required>
        <div class="invalid-feedback">
  Please fill this field
</div></div>

        <!-- Image -->
        <div class="mb-3">
          <label for="image" class="form-label">Image URL</label>
          <input type="text" id="image" name="campground[image]" 
                 class="form-control" value="<%= campground.image %>" required  >
        <div class="invalid-feedback">
  Please fill this field
</div></div>

        <!-- Price -->
        <div class="mb-3">
          <label for="price" class="form-label">Price (per night)</label>
          <input type="number" id="price" name="campground[price]" 
                 class="form-control" value="<%= campground.price %>" min="0" step="0.01" required>
        <div class="invalid-feedback">
  Please fill this field
</div></div>

        <!-- Description -->
        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="campground[description]" 
                    class="form-control" rows="4" required><%= campground.description %></textarea>
        <div class="invalid-feedback">
  Please fill this field
</div></div>

        <!-- Buttons -->
        <div class="d-grid mb-3">
          <button type="submit" class="btn btn-primary">
            Update Campground
          </button>
        </div>

      </form>

      <!-- Back Link -->
      <div class="text-center">
        <a href="/campgrounds/show/<%= campground._id %>" class="btn btn-outline-secondary">
          ← Back to Campground
        </a>
      </div>

    </div>

  </div>
</div>
<% layout('layouts/boilerplate') %>