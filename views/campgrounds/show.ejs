<% layout('layouts/boilerplate') %>
<h1>Campground details:</h1>
<div class="container mt-6">
    <div class="row justify-content-center gx-4">
        <div class="col-md-10 col-lg-5 mb-4">
            <div class="card shadow-lg h-100">
                <img src="<%= campground.image %>" 
                     class="card-img-top" 
                     alt="<%= campground.title %>">

                <div class="card-body">
                    <h2 class="card-title text-primary">
                        <%= campground.title %>
                    </h2>

                    <h5 class="card-subtitle mb-2 text-muted">
                        📍 <%= campground.location %>
                    </h5>

                    <p class="card-text mt-3">
                        <%= campground.description %>
                    </p>

                    <h5 class="text-success">
                        $<%= campground.price %> / night
                    </h5>

                    <div class="mt-4 d-flex gap-2 flex-wrap">
                        <a href="/campgrounds/show/<%= campground._id %>/edit" 
                           class="btn btn-warning">
                           Edit
                        </a>

                        <form action="/campgrounds/show/<%= campground._id %>?_method=DELETE" method="POST">
                            <button type="submit" class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    </div>

                    <div class="mt-3">
                        <a href="/campgrounds" class="btn btn-secondary">
                            Back
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-10 col-lg-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="card-title mb-3">Leave a Review</h2>
                    <form action="/campgrounds/show/<%= campground._id %>/reviews" method="POST" class="mb-4 needs-validation" novalidate>
                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <input type="range" name="review[rating]" class="form-range" min="1" max="5" step="1" required>
                        </div>
                        <div class="mb-3">
                            <label for="review" class="form-label">Your Review</label>
                            <textarea id="review" name="review[body]" class="form-control" rows="3" required></textarea>
                            <div class="invalid-feedback">
                                Please fill this field
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success">Submit Review</button>
                    </form>

                    <div class="reviews-list">
                        <h3 class="h5 mb-3">Recent Reviews</h3>
                        <% if (campground.reviews && campground.reviews.length) { %>
                            <% for(let reviews of campground.reviews){ %>
                                <div class="card border-secondary mb-3">
                                    <div class="card-header bg-white">
                                        <span class="text-warning">
                                            <% for(let i = 1; i <= reviews.rating; i++){ %>
                                                ⭐
                                            <% } %>
                                        </span>
                                    </div>
                                    <div class="card-body py-2">
                                        <p class="card-text mb-0"><%= reviews.body %></p>
                                        <form action="/campgrounds/show/<%= campground._id %>/reviews/<%= reviews._id %>?_method=DELETE" method="POST" class="mt-2">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                Delete
                                            </button>
                                        </form>

                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p class="text-muted">No reviews yet. Be the first to review!</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>